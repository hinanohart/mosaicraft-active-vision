# Per-repo experiment scratch (R8: keep .gitkeep, ignore everything else)
experiments/_wip/*
!experiments/_wip/.gitkeep

# Benchmark + bench plot outputs (must be regenerable). Pinned
# baseline files (phase1_baseline_*.json) are carved out so reviewers
# can diff future runs against the 2026-05-16 numbers.
experiments/results/*
!experiments/results/.gitkeep
!experiments/results/phase1_baseline_*.json
!experiments/results/phase2_baseline_*.json
experiments/plots/

# Vendored mosaicraft submodule build artifacts
external/mosaicraft/**/__pycache__/
external/mosaicraft/**/*.egg-info/

# Misc
.DS_Store
*.log
